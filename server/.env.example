# 后端配置模板：复制为 server/.env 后按需取消注释并修改（.env 已被 git 忽略，不会提交）。
# 命令行显式传入的环境变量优先于本文件，方便临时覆盖（如 PORT=3100 node src/app.js）。

# 后端端口
#PORT=3000

# JWT 签名密钥，生产环境务必改成随机长字符串
#JWT_SECRET=

# ---- B站登录态保活 ----
# 自动检查间隔（小时）；距上次续期超过该天数时自动续期
#BILI_KEEPALIVE_HOURS=12
#BILI_RENEW_DAYS=7

# ---- 上传限制 ----
# 单个视频大小上限（GB）
#MAX_VIDEO_SIZE_GB=2
# 全站未清理视频总量配额（GB）：达到后暂停上传通道，稿件发布/删除后自动释放
#VIDEO_QUOTA_GB=9

# ---- biliup 自动投稿（可选）----
# 默认用 server/bin/ 下自动下载的二进制与 server/data/cookies.json，一般无需配置
#BILIUP_BIN=
#BILIUP_COOKIE=

# ---- 邮件通知（可选）：SMTP_USER 和 SMTP_PASS 都填了才启用 ----
# QQ邮箱：设置 → 账户 → 开启SMTP服务，获取授权码填入 SMTP_PASS
#SMTP_USER=
#SMTP_PASS=
#SMTP_HOST=smtp.qq.com
#SMTP_PORT=465
# 发件人地址，默认同 SMTP_USER
#SMTP_FROM=

# 平台对外访问地址（通知邮件里的审核直达链接会用到），如 https://video.example.com
#SITE_URL=

# 指定系统已安装的 ffmpeg 路径（默认用 npm install 时随 ffmpeg-static 自动安装）
#FFMPEG_PATH=

# 注意：BILIUP_VERSION / BILIUP_GH_MIRROR / BILIUP_SKIP_DOWNLOAD / FFMPEG_BINARIES_URL
# 是 npm install 阶段的下载配置，需以环境变量方式传入，不读本文件。
